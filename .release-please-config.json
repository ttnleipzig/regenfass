{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "package-name": "regenfass",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "json",
          "path": "package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "web/brand/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "web/brand-showcase/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "web/installer/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "web/marketing/package.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "web/docs/package.json",
          "jsonpath": "$.version"
        },
        "web/brand/src/version.ts",
        "firmware/src/version.h",
        "web/dashboard/internal/version/version.go"
      ]
    }
  }
}
